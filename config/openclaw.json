  "tools": {
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "main",
        "dev-odoo-github",
        "dev-odoo-local",
        "dev-distrib-local",
        "dev-validator-deploydev",
        "devops-odoo",
        "incidencias-odoo"
      ]
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": {
        "mode": "partial"
      }
    },
    "mattermost": {
      "enabled": false
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://agentesdev.universidadisep.com",
        "http://localhost:18789",
        "http://localhost:18797",
        "http://127.0.0.1:18789",
        "http://127.0.0.1:18797"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "192.168.100.57",
      "192.168.100.58",
      "127.0.0.1",
      "172.17.0.0/16",
      "10.0.0.0/8"
    ],
    "tailscale": {
      "mode": "off"
    }
  },
  "plugins": {
    "entries": {
      "minimax": {
        "enabled": true
      },
      "ollama": {
        "enabled": true
      }
    }
  },
