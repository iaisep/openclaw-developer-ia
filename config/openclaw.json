        "tools": {
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "dev-distrib-local",
        "name": "Dev Distrib Local",
        "workspace": "/root/.openclaw/workspaces/dev-distrib-local",
        "agentDir": "/root/.openclaw/agents/dev-distrib-local/agent",
        "identity": {
          "name": "Dev Distrib Local",
