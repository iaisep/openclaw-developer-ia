{
  "$schema": "https://openclaw.ai/schema/openclaw.json",
  "models": {
    "mode": "merge",
    "providers": {
      "minimax-portal": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "apiKey": "minimax-oauth",
        "api": "anthropic-messages",
        "authHeader": true,
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "api": "anthropic-messages",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "api": "anthropic-messages",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.5-highspeed",
            "name": "MiniMax M2.5 Highspeed",
            "api": "anthropic-messages",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "ollama": {
        "baseUrl": "http://ollama-api-fw8g04s0w0kcc08008owskok:11434/v1",
        "apiKey": "ollama-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen2.5-7b-gpu:latest",
            "name": "Qwen 2.5 7B Instruct Q4_K_M",
            "api": "openai-completions",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax-portal/MiniMax-M2.5",
        "fallbacks": [
          "ollama/qwen2.5-7b-gpu:latest"
        ]
      },
      "models": {
        "minimax-portal/MiniMax-M2.5": {
          "alias": "MiniMax"
        },
        "minimax-portal/MiniMax-M2.1": {
          "alias": "MiniMax M2.1"
        },
        "ollama/qwen2.5-7b-gpu:latest": {
          "alias": "Qwen 7B"
        }
      },
      "workspace": "/root/.openclaw/workspace",
      "bootstrapMaxChars": 30000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m",
        "keepLastAssistants": 5,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 30000,
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Contenido antiguo limpiado — ver memory/ para contexto guardado]"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "keepRecentTokens": 6000,
        "reserveTokensFloor": 24000,
        "maxHistoryShare": 0.85,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000,
          "prompt": "IMPORTANTE: La sesión se va a compactar. Guarda TODAS las notas duraderas AHORA. Usa write para crear/actualizar memory/YYYY-MM-DD.md con resumen COMPLETO del día.",
          "systemPrompt": "La sesión está cerca de compactarse. ANTES de que se pierda contexto, guarda un resumen EXHAUSTIVO en memory/YYYY-MM-DD.md."
        }
      },
      "timeoutSeconds": 86400,
      "maxConcurrent": 50,
      "subagents": {
        "maxConcurrent": 50,
        "maxSpawnDepth": 3,
        "maxChildrenPerAgent": 15,
        "model": "minimax-portal/MiniMax-M2.5",
        "runTimeoutSeconds": 900
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Developer IA",
        "workspace": "/root/.openclaw/workspace",
        "agentDir": "/root/.openclaw/agents/main/agent",
        "heartbeat": {
          "every": "30m",
          "model": "ollama/qwen2.5-7b-gpu:latest",
          "target": "last",
          "prompt": "Lee HEARTBEAT.md si existe. Verifica tareas pendientes, en progreso con timeout vencido, y fallidas sin reintento. Si hay tareas en cola, delega al sub-agente apropiado. Si todo está en orden, responde HEARTBEAT_OK.",
          "ackMaxChars": 300
        },
        "identity": {
          "name": "Dev Lead IA",
          "theme": "Líder del equipo de desarrollo Odoo 16 — orquesta a los agentes de desarrollo, DevOps e incidencias",
          "emoji": "🏗️"
        },
        "groupChat": {
          "mentionPatterns": [
            "@developer-ia",
            "@dev-ia",
            "@openclaw-developer-ia"
          ]
        },
        "subagents": {
          "allowAgents": [
            "*"
          ]
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "sessions_spawn",
            "sessions_send",
            "sessions_list",
            "sessions_history",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "dev-odoo-github",
        "name": "Dev Odoo GitHub",
        "workspace": "/root/.openclaw/workspaces/dev-odoo-github",
        "agentDir": "/root/.openclaw/agents/dev-odoo-github/agent",
        "identity": {
          "name": "Dev Odoo GitHub",
          "theme": "Desarrollador Odoo 16 — flujo GitHub → DEVMain_Latest → Jenkins → DEV",
          "emoji": "💻"
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "dev-odoo-local",
        "name": "Dev Odoo Local",
        "workspace": "/root/.openclaw/workspaces/dev-odoo-local",
        "agentDir": "/root/.openclaw/agents/dev-odoo-local/agent",
        "identity": {
          "name": "Dev Odoo Local",
          "theme": "Desarrollador Odoo 16 — trabaja en odoo-migration y exporta cambios a /home/maikel/cambios_odoo_local",
          "emoji": "🔧"
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "devops-odoo",
        "name": "DevOps Odoo",
        "workspace": "/root/.openclaw/workspaces/devops-odoo",
        "agentDir": "/root/.openclaw/agents/devops-odoo/agent",
        "heartbeat": {
          "every": "60m",
          "model": "ollama/qwen2.5-7b-gpu:latest",
          "target": "none",
          "prompt": "Sigue el flujo completo del SOUL.md: PASO 0: verifica si DEVMain_Latest tiene commits adelante de main. Si los tiene y no hay PR abierto, crea el PR automáticamente. FASE 1: analiza el diff del PR, evalúa criterios y aprueba o cierra con comentario. FASE 2: tras el merge, espera 3 minutos y valida deploy en producción (Jenkins, contenedor odoo-app-prod, logs, HTTP, upgrade RPC si aplica). Si no hay commits nuevos en DEVMain_Latest ni PRs pendientes, responde HEARTBEAT_OK.",
          "ackMaxChars": 500
        },
        "identity": {
          "name": "DevOps Odoo",
          "theme": "Revisión de Pull Requests DEVMain_Latest → main, aprobación/rechazo con criterio técnico",
          "emoji": "🚀"
        },
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "dev-validator-deploydev",
        "name": "Dev Validator DeployDev",
        "workspace": "/root/.openclaw/workspaces/dev-validator-deploydev",
        "agentDir": "/root/.openclaw/agents/dev-validator-deploydev/agent",
        "identity": {
