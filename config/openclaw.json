            "group:sessions",
            "group:web",
            "exec"
          ],
          "exec": {
            "ask": "off"
          }
        }
      },
      {
        "id": "incidencias-odoo",
        "name": "Incidencias Odoo",
        "workspace": "/root/.openclaw/workspaces/incidencias-odoo",
        "agentDir": "/root/.openclaw/agents/incidencias-odoo/agent",
        "heartbeat": {
          "every": "30m",
          "model": "ollama/qwen2.5-7b-gpu:latest",
          "target": "none",
          "prompt": "Consulta la réplica PostgreSQL en .57: SSH -i /.keys/odoo-dev.pem root@189.195.191.16 docker exec postgres-replica-i4s8o8000kc040cgwcwowwwc psql -U odoo -d UisepFinal. Lee tareas de project_id=53 stage_id=564 (Pendiente). Para cada tarea: analiza la descripción. Si es resoluble via RPC contra app.universidadisep.com resuélvela y muévela a stage 565 (Listo). Si requiere código muévela a stage 703 (Enviado a Proyecto) con nota técnica. Si no hay tareas pendientes, responde HEARTBEAT_OK.",
          "ackMaxChars": 600
